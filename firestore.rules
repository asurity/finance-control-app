rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ⚠️ DEVELOPMENT MODE - OPEN PERMISSIONS ⚠️
    // TODO: Restore strict permissions for production
    // All authenticated users can read/write everything
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Allow all authenticated users to access everything
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Strict rules for voiceUsage (commented for production restoration)
    // match /voiceUsage/{usageId} {
    //   // Estructura del usageId: {userId}_{date}
    //   // Solo el usuario dueño puede leer/escribir sus propios registros
    //   allow read, write: if isAuthenticated() && 
    //                         request.auth.uid == resource.data.userId;
    // }
  }
}
